<Window x:Class="Vdl.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{DynamicResource L.Login.Title}"
        Width="920" Height="640" MinWidth="720" MinHeight="480"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Button Content="{DynamicResource L.Common.Cancel}" Style="{StaticResource SecondaryButton}" Click="OnCancelClick"/>
                    <Button x:Name="FinishButton" Content="{DynamicResource L.Login.Finish}" Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0" Click="OnFinishLoginClick"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="HeadlineText" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="{DynamicResource L.Login.Instruction}"
                               Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="UrlText" FontSize="11.5" Margin="0,2,0,0"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ErrorText" FontSize="11.5" Margin="0,2,0,0"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" Visibility="Collapsed"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <Grid>
            <TextBlock x:Name="InitText" Text="{DynamicResource L.Login.LoadingPage}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}"/>
            <wv2:WebView2 x:Name="WebView"/>
        </Grid>
    </DockPanel>
</Window>
