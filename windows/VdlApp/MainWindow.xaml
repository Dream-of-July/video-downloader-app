<Window x:Class="Vdl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.App.Title}"
        Width="560" Height="780" MinWidth="540" MinHeight="640"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontSize="13"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <DockPanel>

        <!-- 顶部输入区 -->
        <Border DockPanel.Dock="Top" Padding="20,14,20,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="{DynamicResource L.Main.Settings}" Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenSettingsCommand}" ToolTip="{DynamicResource L.Main.Settings}"/>
                <!-- 解析按钮：仅在 idle / failed 阶段作为主按钮，其余阶段降级为次按钮 -->
                <Button DockPanel.Dock="Right" Content="{DynamicResource L.Main.Parse}" Margin="8,0,0,0" MinWidth="56"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ParseCommand}"
                        Visibility="{Binding IsParseProminent, Converter={StaticResource BoolToVis}}"/>
                <Button DockPanel.Dock="Right" Content="{DynamicResource L.Main.Parse}" Margin="8,0,0,0" MinWidth="56"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ParseCommand}"
                        Visibility="{Binding IsParseSecondary, Converter={StaticResource BoolToVis}}"/>
                <Button DockPanel.Dock="Right" Content="{DynamicResource L.Main.Paste}" Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding PasteCommand}"
                        ToolTip="{DynamicResource L.Main.PasteTooltip}"/>
                <Grid>
                    <TextBox x:Name="UrlBox" Padding="8,5" VerticalContentAlignment="Center"
                             Text="{Binding UrlText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ParseCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="{DynamicResource L.Main.UrlPlaceholder}" Margin="11,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource TertiaryTextBrush}" IsHitTestVisible="False"
                               Visibility="{Binding UrlText, Converter={StaticResource EmptyToVis}}"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- 队列区：空队列整个隐藏；非空时默认收成一条摘要栏，点击展开/收起（高度动画在 code-behind）。
             新任务入队会自动「探出」展示片刻再收起，让用户看到任务确实进了队列。 -->
        <Border x:Name="QueuePanel" DockPanel.Dock="Bottom" Height="44" ClipToBounds="True"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding HasQueueItems, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 摘要栏：标题 + 任务摘要 + 展开/收起箭头，整条可点 -->
                <Button Grid.Row="0" Style="{StaticResource QueueBarButton}"
                        Command="{Binding ToggleQueueCommand}">
                    <Button.ToolTip>
                        <ToolTip>
                            <ToolTip.Style>
                                <Style TargetType="ToolTip">
                                    <Setter Property="Content" Value="{DynamicResource L.Queue.ExpandTooltip}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsQueueExpanded}" Value="True">
                                            <Setter Property="Content" Value="{DynamicResource L.Queue.CollapseTooltip}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToolTip.Style>
                        </ToolTip>
                    </Button.ToolTip>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE70E;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsQueueExpanded}" Value="True">
                                            <Setter Property="Text" Value="&#xE70D;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource L.Queue.Header}" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding QueueSummary}" FontSize="11.5" Margin="10,0,0,0"
                                       Foreground="{StaticResource TertiaryTextBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding QueueSummary, Converter={StaticResource TextToVis}}"/>
                        </StackPanel>
                    </DockPanel>
                </Button>

                <!-- 队列主体：收起态折叠（动画结束后由 code-behind 设 Collapsed） -->
                <Border x:Name="QueueBody" Grid.Row="1" Opacity="0" Visibility="Collapsed">
                    <DockPanel>
                        <Border DockPanel.Dock="Bottom" Padding="16,5"
                                BorderBrush="{StaticResource RowDividerBrush}" BorderThickness="0,1,0,0"
                                Visibility="{Binding HasFinishedItems, Converter={StaticResource BoolToVis}}">
                            <Button Content="{DynamicResource L.Queue.ClearFinished}" HorizontalAlignment="Right" FontSize="11.5"
                                    Style="{StaticResource LinkButton}"
                                    Command="{Binding ClearFinishedCommand}"/>
                        </Border>
                        <ListBox ItemsSource="{Binding QueueRows}"
                                 BorderThickness="0" Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,9"
                                            BorderBrush="{StaticResource RowDividerBrush}" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                                <Button Content="{DynamicResource L.Row.Pause}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding PauseCommand}" ToolTip="{DynamicResource L.Row.Pause}"
                                                        Visibility="{Binding ShowPause, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{DynamicResource L.Row.Resume}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding ResumeCommand}" ToolTip="{DynamicResource L.Row.Resume}"
                                                        Visibility="{Binding ShowResume, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{DynamicResource L.Row.Cancel}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding CancelCommand}" ToolTip="{DynamicResource L.Row.Cancel}"
                                                        Visibility="{Binding ShowCancel, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{DynamicResource L.Row.RetrySubtitle}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding RetryCommand}" ToolTip="{DynamicResource L.Row.RetrySubtitle}"
                                                        Visibility="{Binding ShowRetrySubtitle, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{DynamicResource L.Row.Retry}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding RetryCommand}" ToolTip="{DynamicResource L.Row.Retry}"
                                                        Visibility="{Binding ShowRetry, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{DynamicResource L.Row.Reveal}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding RevealCommand}" ToolTip="{DynamicResource L.Row.RevealTooltip}"
                                                        Visibility="{Binding ShowReveal, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="{DynamicResource L.Row.Remove}" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                        Command="{Binding RemoveCommand}" ToolTip="{DynamicResource L.Row.Remove}"
                                                        Visibility="{Binding ShowRemove, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Title}"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11.5" Margin="0,3,0,0"
                                                           TextWrapping="Wrap" MaxHeight="32"
                                                           ToolTip="{Binding StatusText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <ProgressBar Height="4" Margin="0,6,0,0" Minimum="0" Maximum="1"
                                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                                             IsIndeterminate="{Binding ProgressIndeterminate}"
                                                             Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                                                    <ProgressBar.Style>
                                                        <Style TargetType="ProgressBar">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                    <Setter Property="Foreground" Value="#9E9EA3"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ProgressBar.Style>
                                                </ProgressBar>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 中部内容：按阶段切换 -->
        <Grid>

            <!-- idle 空状态 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="48" Foreground="#C7C7CC" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource L.Idle.Headline}" FontSize="13.5" Margin="0,14,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource L.Idle.Sub}" Margin="0,6,0,0"
                           Style="{StaticResource Caption}" Foreground="{StaticResource TertiaryTextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding EnqueueNotice}" Margin="0,12,0,0" MaxWidth="380"
                           Style="{StaticResource Caption}" HorizontalAlignment="Center"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding EnqueueNotice}"
                           Visibility="{Binding EnqueueNotice, Converter={StaticResource TextToVis}}"/>
            </StackPanel>

            <!-- 解析中 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoadingStage, Converter={StaticResource BoolToVis}}">
                <ProgressBar Width="200" Height="4" IsIndeterminate="True"
                             Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="{Binding LoadingText}" Margin="0,14,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource L.Loading.BatchHint}" Margin="0,6,0,0"
                           Style="{StaticResource Caption}" Foreground="{StaticResource TertiaryTextBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsBatchLoading, Converter={StaticResource BoolToVis}}"/>
                <Button Content="{DynamicResource L.Common.Cancel}" Margin="0,16,0,0" HorizontalAlignment="Center"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelParseCommand}"/>
            </StackPanel>

            <!-- 多候选选择 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsChoosing, Converter={StaticResource BoolToVis}}">
                <StackPanel MaxWidth="500" Margin="20,4,20,20">
                    <TextBlock Text="{Binding ChoosingTitle}" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                    <Border Style="{StaticResource Card}" Padding="4">
                        <ItemsControl ItemsSource="{Binding Candidates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RowButton}"
                                            Command="{Binding DataContext.ChooseCandidateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="&#x203A;" FontSize="16"
                                                       Foreground="{StaticResource TertiaryTextBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxHeight="40"
                                                           ToolTip="{Binding Title}"/>
                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource Caption}" Margin="0,2,0,0"
                                                           Visibility="{Binding Detail, Converter={StaticResource TextToVis}}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ready：选择卡片 -->
            <DockPanel Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                <Border DockPanel.Dock="Bottom" Padding="20,12,20,14">
                    <StackPanel MaxWidth="500">
                        <Button Content="{DynamicResource L.Ready.Enqueue}" FontSize="14" Padding="0,8"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding StartDownloadCommand}"/>
                        <Grid Margin="0,7,0,0">
                            <TextBlock Text="{DynamicResource L.Ready.SaveHint}"
                                       Style="{StaticResource Caption}" HorizontalAlignment="Center"
                                       Visibility="{Binding EnqueueNotice, Converter={StaticResource EmptyToVis}}"/>
                            <!-- 重复入队等提示就地显示，避免点了按钮毫无反馈 -->
                            <TextBlock Text="{Binding EnqueueNotice}" FontSize="11.5"
                                       Foreground="{StaticResource WarnBrush}" HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding EnqueueNotice, Converter={StaticResource TextToVis}}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="500" Margin="20,0,20,8">
                        <Button Content="{DynamicResource L.Ready.BackToList}" HorizontalAlignment="Left" Margin="0,2,0,0"
                                Style="{StaticResource LinkButton}"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Command="{Binding BackToListCommand}"
                                Visibility="{Binding CanReturnToList, Converter={StaticResource BoolToVis}}"/>
                        <Border Style="{StaticResource Card}" Padding="12" Margin="0,8,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="160" Height="90" CornerRadius="8"
                                        Background="#ECECF0" Margin="0,0,12,0">
                                    <Border CornerRadius="8">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="{Binding ReadyTitle}" FontWeight="SemiBold"
                                               TextWrapping="Wrap" MaxHeight="40" ToolTip="{Binding ReadyTitle}"/>
                                    <TextBlock Text="{Binding ReadyMeta}" Style="{StaticResource Caption}" Margin="0,5,0,0"
                                               Visibility="{Binding ReadyMeta, Converter={StaticResource TextToVis}}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Ready.FormatSection}" Style="{StaticResource SectionHeader}" Margin="0,16,0,8"/>
                        <Border Style="{StaticResource Card}" Padding="12,10">
                            <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Label}"/>
                                            <TextBlock Text="{Binding Detail}" Margin="8,0,0,0"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Visibility="{Binding Detail, Converter={StaticResource TextToVis}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Ready.SubtitleSection}" Style="{StaticResource SectionHeader}" Margin="0,16,0,8"/>
                        <Border Style="{StaticResource Card}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Ready.NoSubtitles}" Margin="0,4"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Visibility="{Binding HasNoSubtitles, Converter={StaticResource BoolToVis}}"/>
                                <ItemsControl ItemsSource="{Binding SubtitleOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,5" VerticalContentAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Label}"/>
                                                    <Border Background="#ECECF0" CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                                            Visibility="{Binding IsAuto, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{DynamicResource L.Ready.AutoTag}" FontSize="10.5"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Ready.ProcessSection}" Style="{StaticResource SectionHeader}" Margin="0,16,0,8"/>
                        <Border Style="{StaticResource Card}" Padding="12">
                            <StackPanel>
                                <StackPanel IsEnabled="{Binding ChineseModeEnabled}">
                                    <RadioButton Content="{DynamicResource L.Mode.Off}" GroupName="ChineseMode" Margin="0,3"
                                                 IsChecked="{Binding ChineseModeOff}"/>
                                    <RadioButton Content="{DynamicResource L.Mode.SrtOnly}" GroupName="ChineseMode" Margin="0,3"
                                                 IsChecked="{Binding ChineseModeSrtOnly}"/>
                                    <RadioButton Content="{DynamicResource L.Mode.BurnIn}" GroupName="ChineseMode" Margin="0,3"
                                                 IsChecked="{Binding ChineseModeBurnIn}"/>
                                    <!-- 直压模式：不翻译直接把所选字幕压进视频，无需配置翻译服务 -->
                                    <RadioButton Content="{DynamicResource L.Mode.BurnOriginal}" GroupName="ChineseMode" Margin="0,3"
                                                 IsChecked="{Binding ChineseModeBurnOriginal}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ChineseHintText}" Style="{StaticResource Caption}" Margin="0,6,0,0"
                                           Visibility="{Binding ChineseHintText, Converter={StaticResource TextToVis}}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            Visibility="{Binding ShowTranslationUnconfigured, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{DynamicResource L.Ready.NotConfigured}" Style="{StaticResource Caption}"/>
                                    <Button Content="{DynamicResource L.Ready.GoSettings}" FontSize="11.5" Margin="8,0,0,0"
                                            Style="{StaticResource LinkButton}"
                                            Command="{Binding OpenSettingsCommand}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ChineseSourceNote}" Style="{StaticResource Caption}" Margin="0,6,0,0"
                                           Visibility="{Binding ChineseSourceNote, Converter={StaticResource TextToVis}}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- 失败 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsFailedStage, Converter={StaticResource BoolToVis}}">
                <StackPanel MaxWidth="460" HorizontalAlignment="Center" Margin="20,40,20,20">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="36" Foreground="#E08700" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding FailedHeadline}" Margin="0,14,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="{Binding FailedDetail}" Margin="0,8,0,0"
                               Style="{StaticResource Caption}" TextAlignment="Center"
                               Visibility="{Binding FailedDetail, Converter={StaticResource TextToVis}}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Button Content="{DynamicResource L.Failed.GoLogin}" Style="{StaticResource PrimaryButton}"
                                Command="{Binding GoLoginCommand}"
                                Visibility="{Binding ShowGoLogin, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="{DynamicResource L.Common.Retry}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                                Command="{Binding RetryCommand}"
                                Visibility="{Binding ShowRetryPrimary, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="{DynamicResource L.Common.Retry}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding RetryCommand}"
                                Visibility="{Binding ShowRetrySecondary, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="{DynamicResource L.Failed.Restart}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding ResetCommand}"/>
                        <Button Content="{DynamicResource L.Failed.BackToList}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding BackToListCommand}"
                                Visibility="{Binding CanReturnToList, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
