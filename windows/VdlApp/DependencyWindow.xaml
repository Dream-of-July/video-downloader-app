<Window x:Class="Vdl.App.DependencyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <StackPanel Margin="20,18">
        <TextBlock x:Name="CaptionText" TextWrapping="Wrap"/>
        <ProgressBar x:Name="Bar" Height="4" Margin="0,14,0,0" IsIndeterminate="True"
                     Foreground="{StaticResource AccentBrush}"/>
        <TextBlock x:Name="StatusText" Margin="0,10,0,0" Style="{StaticResource Caption}"/>
        <TextBlock x:Name="ErrorText" FontSize="11.5" Margin="0,8,0,0"
                   Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap"
                   Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CloseButton" Content="{DynamicResource L.Common.Close}" Style="{StaticResource SecondaryButton}"
                    Visibility="Collapsed" Click="OnCloseClick"/>
            <Button x:Name="RetryButton" Content="{DynamicResource L.Common.Retry}" Style="{StaticResource PrimaryButton}"
                    Margin="8,0,0,0" Visibility="Collapsed" Click="OnRetryClick"/>
        </StackPanel>
    </StackPanel>
</Window>
